VITE_HOST=0.0.0.0
VITE_PORT=5173
# Путь same-origin использует dev-proxy Vite (см. `vite.config.ts`). Переопределите для прямого адреса API.
VITE_API_BASE_URL=/api/v1
VITE_API_PROXY_TARGET=http://api:8000
VITE_ALLOWED_HOSTS=localhost,127.0.0.1,notebook.com

# Включение локального режима WebLLM
# Чтобы выключить локальный ИИ в браузере для локальной разработки, удалите:
VITE_WEBLLM_LOCAL_MODE_ROLLOUT_POLICY=dev-opt-in
VITE_WEBLLM_LOCAL_MODE_ENABLED=true
# Необязательная настройка локального рантайма:
# VITE_WEBLLM_MODEL=Llama-3.2-1B-Instruct-q4f32_1-MLC
# VITE_WEBLLM_BOOTSTRAP_TIMEOUT_MS=120000
