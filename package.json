{
  "name": "js-notebook-ui",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext ts,tsx --max-warnings 0 && steiger ./src",
    "lint:fsd": "steiger ./src",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc -b --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "verify": "pnpm typecheck && pnpm lint && pnpm format:check && pnpm test",
    "verify:commit": "pnpm lint-staged && pnpm typecheck && pnpm lint && pnpm lint:fsd && pnpm test",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix --max-warnings 0",
      "prettier --write"
    ],
    "*.{json,md,css,mjs,cjs}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@codemirror/lang-javascript": "^6.2.4",
    "@codemirror/state": "^6.5.2",
    "@codemirror/view": "^6.38.1",
    "@fontsource-variable/geist": "^5.2.9",
    "@radix-ui/react-slot": "^1.2.4",
    "@tanstack/react-query": "^5.87.1",
    "@uiw/react-codemirror": "^4.25.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dexie": "^4.2.0",
    "lucide-react": "^1.16.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.8.2",
    "recharts": "^2.15.3",
    "shadcn": "^4.7.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.1.5",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.13.0",
    "@feature-sliced/steiger-plugin": "^0.5.8",
    "@playwright/test": "^1.54.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.12.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^8.14.0",
    "@typescript-eslint/parser": "^8.14.0",
    "@vitejs/plugin-react": "^6.0.2",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.13.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-boundaries": "^6.0.2",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.13",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.5",
    "msw": "^2.11.1",
    "postcss": "^8.4.47",
    "prettier": "^3.8.3",
    "steiger": "^0.5.12",
    "tailwindcss": "^3.4.13",
    "typescript": "^5.6.3",
    "vite": "^8.0.13",
    "vitest": "^4.1.6"
  },
  "overrides": {
    "esbuild": "^0.28.0"
  }
}
